# Godot 4+ specific ignores
.godot/
/android/
*.translation

# C# / .NET (generated when first script is added)
.mono/
*.csproj.user
bin/
obj/

# Local archive of source bundles — keep out of git
_archive/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
# Python caches
__pycache__/
*.py[cod]

# Bootstrapped Godot API doc source (regenerate via ensure_doc_api.sh)
.claude/skills/godot-api/doc_source/godot/

# Python test cache
.pytest_cache/

# Local agent workflow and secrets (not shared canon)
.omx/
.secrets/
omx_wiki/

# Visual capture outputs (regenerate via scripts/capture_*.sh)
screenshots/

# CI / local build outputs
build/
reports/
.nuget/

# Machine-local capture config
.capture/env
